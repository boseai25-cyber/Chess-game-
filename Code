func create_output_turn_section():
	# Section title
	var turn_title = Label.new()
	turn_title.text = "═══ CURRENT TURN ═══"
	turn_title.add_theme_font_size_override("font_size", 18)
	turn_title.add_theme_color_override("font_color", Color(0.4, 1.0, 0.4))
	output_container.add_child(turn_title)
	
	# Turn display
	turn_display = Label.new()
	turn_display.name = "OutputTurnDisplay"
	turn_display.text = "WHITE'S TURN"
	turn_display.add_theme_font_size_override("font_size", 24)
	turn_display.add_theme_color_override("font_color", Color.WHITE)
	turn_display.alignment = HORIZONTAL_ALIGNMENT_CENTER
	output_container.add_child(turn_display)
	
	# Move counter
	var move_label = Label.new()
	move_label.name = "OutputMoveLabel"
	move_label.text = "Move: 1"
	move_label.add_theme_font_size_override("font_size", 14)
	move_label.add_theme_color_override("font_color", Color(0.8, 0.8, 0.8))
	move_label.alignment = HORIZONTAL_ALIGNMENT_CENTER
	output_container.add_child(move_label)
	
