extends Sprite2D

const BOARD_SIZE = 8
const CELL_WIDTH = 81

const texture_holder = preload("res://texture_holder.tscn")

const B_bishop = preload("res://sprite/B_bishop.png")
const B_horse = preload("res://sprite/B_horse.png")
const B_king = preload("res://sprite/B_king.png")
const B_queen = preload("res://sprite/B_queen.png")
const B_rook = preload("res://sprite/B_rook.png")
const B_soilder = preload("res://sprite/B_solider.png")
const w_bishop = preload("res://sprite/W_bishop.png")
const w_horse = preload("res://sprite/W_horse.png")
const w_king = preload("res://sprite/W_king.png")
const w_queen = preload("res://sprite/W_queen.png")
const w_rook = preload("res://sprite/W_rook.png")
const w_soilder = preload("res://sprite/W_soilder.png")

const turn_black = preload("res://sprite/turn-black.png")
const turn_white = preload("res://sprite/turn-white.png")

const piece_move = preload("res://sprite/Piece_move.png")

@onready var piece = $piece
@onready var dot = $dot
@onready var turn = $turn
var clock_timer = null
var white_time_label = null
var black_time_label = null

# piece constants (positive = white, negative = black)
const EMPTY = 0
const W_PAWN = 1
const W_KNIGHT = 2
const W_BISHOP = 3
const W_ROOK = 4
const W_QUEEN = 5
const W_KING = 6

var board : Array = []
var white_turn : bool = true
var selecting : bool = true
var moves : Array = []
var selected_piece : Vector2 = Vector2(-1, -1)
var promotion_square = null
var white_captured : Array =[]  
var black_captured : Array =[]  

# timers (seconds)
var white_time : int = 300
var black_time : int = 300

func _ready():
	# assign optional nodes if present
	if has_node("ClockTimer"):
		clock_timer = $ClockTimer
	if has_node("WhiteTime"):
		white_time_label = $WhiteTime
	if has_node("BlackTime"):
		black_time_label = $BlackTime



	board = []
	board.append([W_ROOK, W_KNIGHT, W_BISHOP, W_QUEEN, W_KING, W_BISHOP, W_KNIGHT, W_ROOK])
	board.append([W_PAWN, W_PAWN, W_PAWN, W_PAWN, W_PAWN, W_PAWN, W_PAWN, W_PAWN])
	board.append([EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY])
	board.append([EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY])
	board.append([EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY])
	board.append([EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY, EMPTY])
	board.append([-W_PAWN, -W_PAWN, -W_PAWN, -W_PAWN, -W_PAWN, -W_PAWN, -W_PAWN, -W_PAWN])
	board.append([-W_ROOK, -W_KNIGHT, -W_BISHOP, -W_QUEEN, -W_KING, -W_BISHOP, -W_KNIGHT, -W_ROOK])

	if clock_timer:
		clock_timer.wait_time = 1
		clock_timer.connect("timeout", Callable(self, "_on_clock_tick"))
		clock_timer.start()

	display_board()

func _input(event):
	if event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
		var mp = get_global_mouse_position()
		if is_mouse_out(mp):
			return
		var col = int(mp.x / CELL_WIDTH)
		var row = int(-mp.y / CELL_WIDTH)
		if not selecting:
			var val = board[row][col]
			if val != EMPTY and ((white_turn and val > 0) or (not white_turn and val < 0)):
				selected_piece = Vector2(row, col)
				moves = get_legal_moves_from(selected_piece)
				if moves.size() == 0:
					selecting = false
				else:
					show_dots()
					selecting = true
		else:
			set_move(row, col)

func is_mouse_out(mp: Vector2) -> bool:
	if mp.x < 0 or mp.x >= BOARD_SIZE * CELL_WIDTH: return true
	if mp.y > 0 or mp.y <= -BOARD_SIZE * CELL_WIDTH: return true
	return false

func display_board():
	for child in piece.get_children():
		child.queue_free()

	for i in range(BOARD_SIZE):
		for j in range(BOARD_SIZE):
			var holder = texture_holder.instantiate()
			piece.add_child(holder)
			holder.global_position = Vector2(j * CELL_WIDTH + (CELL_WIDTH / 2), -i * CELL_WIDTH - (CELL_WIDTH / 2))
			match board[i][j]:
				-6: holder.texture = B_king
				-5: holder.texture = B_queen
				-4: holder.texture = B_rook
				-3: holder.texture = B_bishop
				-2: holder.texture = B_horse
				-1: holder.texture = B_soilder
				0: holder.texture = null
				6: holder.texture = w_king
				5: holder.texture = w_queen
				4: holder.texture = w_rook
				3: holder.texture = w_bishop
				2: holder.texture = w_horse
				1: holder.texture = w_soilder

	if white_turn:
		turn.texture = turn_white
	else:
		turn.texture = turn_black
	_update_timer_labels()

func show_options():
	moves = get_legal_moves_from(selected_piece)
	if moves.size() == 0:
		selecting = false
		return
	show_dots()

func show_dots():
	delete_dots()
	for i in moves:
		var holder = texture_holder.instantiate()
		dot.add_child(holder)
		holder.texture = piece_move
		holder.global_position = Vector2(i.y * CELL_WIDTH + (CELL_WIDTH / 2), -i.x * CELL_WIDTH - (CELL_WIDTH / 2))

func delete_dots():
	for child in dot.get_children():
		child.queue_free()

func set_move(target_row: int, target_col: int):
	for i in moves:
		if i.x == target_row and i.y == target_col:
			var piece_val = board[selected_piece.x][selected_piece.y]
			var captured = board[target_row][target_col]
			# Track captured piece
			if captured != EMPTY:
				if captured > 0:
					white_captured.append(captured)
				else:
					black_captured.append(captured)
			# handle pawn promotion (auto-queen). Promotion_square can be used to trigger UI instead.
			if abs(piece_val) == W_PAWN:
				if piece_val > 0 and target_row == 7:
					board[target_row][target_col] = W_QUEEN
				elif piece_val < 0 and target_row == 0:
					board[target_row][target_col] = -W_QUEEN
				else:
					board[target_row][target_col] = piece_val
			else:
				board[target_row][target_col] = piece_val
			board[selected_piece.x][selected_piece.y] = EMPTY
			white_turn = not white_turn
			display_board()
			break
	delete_dots()
	moves.clear()
	selecting = false
	_post_move_checks()

func get_moves_for_square(pos: Vector2) -> Array:
	var saved_selected = selected_piece
	selected_piece = pos
	var _move = []
	var val = board[pos.x][pos.y]
	if val == EMPTY:
		selected_piece = saved_selected
		return _move
	match abs(val):
		W_PAWN:
			_move = get_pawn_moves()
		W_KNIGHT:
			_move = get_knight_moves()
		W_BISHOP:
			_move = get_bishop_moves()
		W_ROOK:
			_move = get_rook_moves()
		W_QUEEN:
			_move = get_queen_moves()
		W_KING:
			_move = get_king_moves()
	selected_piece = saved_selected
	return _move

func get_legal_moves_from(from_pos: Vector2) -> Array:
	var legal = []
	var pseudo = get_moves_for_square(from_pos)
	for to in pseudo:
		if not _would_cause_self_check(from_pos, to):
			legal.append(to)
	return legal

func get_legal_moves() -> Array:
	var legal = []
	var side_sign = 1 if white_turn else -1
	for r in range(BOARD_SIZE):
		for c in range(BOARD_SIZE):
			if board[r][c] * side_sign > 0:
				var from = Vector2(r, c)
				var pseudo = get_moves_for_square(from)
				for to in pseudo:
					if not _would_cause_self_check(from, to):
						legal.append(to)
	return legal

func _would_cause_self_check(from: Vector2, to: Vector2) -> bool:
	var copyb = _copy_board(board)
	var moving = copyb[from.x][from.y]
	copyb[to.x][to.y] = moving
	copyb[from.x][from.y] = EMPTY
	return _is_in_check_state(copyb, white_turn)

func _copy_board(src: Array) -> Array:
	var out = []
	for row in src:
		var newr = []
		for v in row:
			newr.append(v)
		out.append(newr)
	return out

func _is_in_check_state(bd: Array, check_white: bool) -> bool:
	# find king
	var king_val = W_KING if check_white else -W_KING
	var king_pos = null
	for r in range(BOARD_SIZE):
		for c in range(BOARD_SIZE):
			if bd[r][c] == king_val:
				king_pos = Vector2(r, c)
				break
		if king_pos: break
	if king_pos == null:
		return false
	# iterate opponent pieces and see if any pseudo-legal move hits the king
	var opp_sign = -1 if check_white else 1
	for r in range(BOARD_SIZE):
		for c in range(BOARD_SIZE):
			if bd[r][c] * opp_sign > 0:
				var piece_type = abs(bd[r][c])
				var from_pos = Vector2(r, c)
				var moves_local = []
				match piece_type:
					W_PAWN:
						moves_local = _pawn_moves_on_board(bd, from_pos)
					W_KNIGHT:
						moves_local = _knight_moves_on_board(bd, from_pos)
					W_BISHOP:
						moves_local = _bishop_moves_on_board(bd, from_pos)
					W_ROOK:
						moves_local = _rook_moves_on_board(bd, from_pos)
					W_QUEEN:
						moves_local = _queen_moves_on_board(bd, from_pos)
					W_KING:
						moves_local = _king_moves_on_board(bd, from_pos)
				for m in moves_local:
					if m == king_pos:
						return true
	return false

func _post_move_checks():
	# after each move, check for check, checkmate, stalemate
	var in_check = _is_in_check_state(board, white_turn)
	var has_legal = false
	for r in range(BOARD_SIZE):
		for c in range(BOARD_SIZE):
			if board[r][c] == EMPTY: continue
			if (white_turn and board[r][c] > 0) or (not white_turn and board[r][c] < 0):
				var from = Vector2(r, c)
				var pseudo = get_moves_for_square(from)
				for to in pseudo:
					if not _would_cause_self_check(from, to):
						has_legal = true
						break
				if has_legal:
					break
		if has_legal: break
	if not has_legal:
		if in_check:
			print("Checkmate! " + ("White" if (not white_turn) else "Black") + " wins.")
		else:
			print("Stalemate! Draw.")
	else:
		if in_check:
			print(("White" if white_turn else "Black") + " is in check.")

# ---- move generation helpers (operate on current board) ----
func get_rook_moves() -> Array:
	var _move = []
	var directions = [Vector2(0, 1), Vector2(0, -1), Vector2(1, 0), Vector2(-1, 0)]
	for d in directions:
		_move += ray_moves_on_board(board, selected_piece, d)
	return _move

func get_bishop_moves() -> Array:
	var _move = []
	var directions = [Vector2(1, 1), Vector2(-1, 1), Vector2(1, -1), Vector2(-1, -1)]
	for d in directions:
		_move += ray_moves_on_board(board, selected_piece, d)
	return _move

func get_queen_moves() -> Array:
	var _move = []
	var directions = [Vector2(0, 1), Vector2(0, -1), Vector2(1, 0), Vector2(-1, 0), Vector2(1, 1), Vector2(1, -1), Vector2(-1, 1), Vector2(-1, -1)]
	for d in directions:
		_move += ray_moves_on_board(board, selected_piece, d)
	return _move

func get_king_moves() -> Array:
	var _move = []
	var directions = [Vector2(0, 1), Vector2(0, -1), Vector2(1, 0), Vector2(-1, 0), Vector2(1, 1), Vector2(1, -1), Vector2(-1, 1), Vector2(-1, -1)]
	for d in directions:
		var pos = selected_piece + d
		if is_inside(pos):
			if is_empty(pos) or is_enemy(pos):
				_move.append(pos)
	return _move

func get_knight_moves() -> Array:
	var _move = []
	var directions = [Vector2(2, 1), Vector2(2, -1), Vector2(1, 2), Vector2(-1, 2), Vector2(-2, 1), Vector2(-2, -1), Vector2(1, -2), Vector2(-1, -2)]
	for d in directions:
		var pos = selected_piece + d
		if is_inside(pos) and (is_empty(pos) or is_enemy(pos)):
			_move.append(pos)
	return _move

func get_pawn_moves() -> Array:
	var _move = []
	var piece_val = board[selected_piece.x][selected_piece.y]
	var direction = Vector2(1, 0) if piece_val > 0 else Vector2(-1, 0)
	var start_row = 1 if piece_val > 0 else 6
	var forward = selected_piece + direction
	if is_inside(forward) and is_empty(forward):
		_move.append(forward)
	var double = selected_piece + direction * 2
	if selected_piece.x == start_row and is_inside(double) and is_empty(double) and is_empty(selected_piece + direction):
		_move.append(double)
	var cap_left = selected_piece + Vector2(direction.x, -1)
	if is_inside(cap_left) and is_enemy(cap_left):
		_move.append(cap_left)
	var cap_right = selected_piece + Vector2(direction.x, 1)
	if is_inside(cap_right) and is_enemy(cap_right):
		_move.append(cap_right)
	return _move

func ray_moves_on_board(bd: Array, from_pos: Vector2, direction: Vector2) -> Array:
	var res = []
	var pos = from_pos + direction
	while pos.x >= 0 and pos.x < BOARD_SIZE and pos.y >= 0 and pos.y < BOARD_SIZE:
		if bd[pos.x][pos.y] == EMPTY:
			res.append(pos)
		elif (bd[pos.x][pos.y] > 0 and bd[from_pos.x][from_pos.y] < 0) or (bd[pos.x][pos.y] < 0 and bd[from_pos.x][from_pos.y] > 0):
			res.append(pos)
			break
		else:
			break
		pos += direction
	return res

# board-specific move generators for check detection (operate on provided board)
func _pawn_moves_on_board(bd: Array, from_pos: Vector2) -> Array:
	var sp = from_pos
	var val = bd[sp.x][sp.y]
	var direction = Vector2(1, 0) if val > 0 else Vector2(-1, 0)
	var out = []
	var left = sp + Vector2(direction.x, -1)
	var right = sp + Vector2(direction.x, 1)
	if left.x >= 0 and left.x < BOARD_SIZE and left.y >= 0 and left.y < BOARD_SIZE:
		if bd[left.x][left.y] != EMPTY and ((val > 0 and bd[left.x][left.y] < 0) or (val < 0 and bd[left.x][left.y] > 0)):
			out.append(left)
	if right.x >= 0 and right.x < BOARD_SIZE and right.y >= 0 and right.y < BOARD_SIZE:
		if bd[right.x][right.y] != EMPTY and ((val > 0 and bd[right.x][right.y] < 0) or (val < 0 and bd[right.x][right.y] > 0)):
			out.append(right)
	return out

func _knight_moves_on_board(bd: Array, from_pos: Vector2) -> Array:
	var out = []
	var dirs = [Vector2(2, 1), Vector2(2, -1), Vector2(1, 2), Vector2(-1, 2), Vector2(-2, 1), Vector2(-2, -1), Vector2(1, -2), Vector2(-1, -2)]
	var val = bd[from_pos.x][from_pos.y]
	for d in dirs:
		var p = from_pos + d
		if p.x >= 0 and p.x < BOARD_SIZE and p.y >= 0 and p.y < BOARD_SIZE:
			if bd[p.x][p.y] == EMPTY or (bd[p.x][p.y] > 0 and val < 0) or (bd[p.x][p.y] < 0 and val > 0):
				out.append(p)
	return out

func _bishop_moves_on_board(bd: Array, from_pos: Vector2) -> Array:
	var out = []
	var dirs = [Vector2(1, 1), Vector2(-1, 1), Vector2(1, -1), Vector2(-1, -1)]
	for d in dirs:
		out += ray_moves_on_board(bd, from_pos, d)
	return out

func _rook_moves_on_board(bd: Array, from_pos: Vector2) -> Array:
	var out = []
	var dirs = [Vector2(0, 1), Vector2(0, -1), Vector2(1, 0), Vector2(-1, 0)]
	for d in dirs:
		out += ray_moves_on_board(bd, from_pos, d)
	return out

func _queen_moves_on_board(bd: Array, from_pos: Vector2) -> Array:
	var out = []
	var dirs = [Vector2(0, 1), Vector2(0, -1), Vector2(1, 0), Vector2(-1, 0), Vector2(1, 1), Vector2(1, -1), Vector2(-1, 1), Vector2(-1, -1)]
	for d in dirs:
		out += ray_moves_on_board(bd, from_pos, d)
	return out

func _king_moves_on_board(bd: Array, from_pos: Vector2) -> Array:
	var out = []
	var dirs = [Vector2(0, 1), Vector2(0, -1), Vector2(1, 0), Vector2(-1, 0), Vector2(1, 1), Vector2(1, -1), Vector2(-1, 1), Vector2(-1, -1)]
	var val = bd[from_pos.x][from_pos.y]
	for d in dirs:
		var p = from_pos + d
		if p.x >= 0 and p.x < BOARD_SIZE and p.y >= 0 and p.y < BOARD_SIZE:
			if bd[p.x][p.y] == EMPTY or (bd[p.x][p.y] > 0 and val < 0) or (bd[p.x][p.y] < 0 and val > 0):
				out.append(p)
	return out

func is_inside(pos: Vector2) -> bool:
	return pos.x >= 0 and pos.x < BOARD_SIZE and pos.y >= 0 and pos.y < BOARD_SIZE

func is_empty(pos: Vector2) -> bool:
	return board[pos.x][pos.y] == EMPTY

func is_enemy(pos: Vector2) -> bool:
	var selected_val = board[selected_piece.x][selected_piece.y]
	var target_val = board[pos.x][pos.y]
	if target_val == EMPTY:
		return false
	return (selected_val > 0 and target_val < 0) or (selected_val < 0 and target_val > 0)

func promote(_var : Vector2):
	promotion_square = _var
	# Placeholder for promotion UI; by default we auto-promote to queen
	var r = int(_var.x)
	var c = int(_var.y)
	if board[r][c] > 0:
		board[r][c] = W_QUEEN
	elif board[r][c] < 0:
		board[r][c] = -W_QUEEN
	display_board()

# Timer tick
func _on_clock_tick():
	if white_turn:
		white_time -= 1
	else:
		black_time -= 1
	_update_timer_labels()
	if white_time <= 0 or black_time <= 0:
		if clock_timer:
			clock_timer.stop()
		print("Time up! " + ("Black" if white_time <= 0 else "White") + " wins by timeout.")

func _update_timer_labels():
	if white_time_label:
		white_time_label.text = _format_time(white_time)
	if black_time_label:
		black_time_label.text = _format_time(black_time)

func _format_time(sec: int) -> String:
	if sec < 0:
		sec = 0
	var m = sec / 60
	var s = sec % 60
	var ms = str(m)
	var ss = str(s)
	if ms.length() < 2:
		ms = "0" + ms
	if ss.length() < 2:
		ss = "0" + ss
	return ms + ":" + ss

